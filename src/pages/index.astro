---
import Layout from '../layouts/Layout.astro';

import Column from '../layouts/Column';
import Base from '../layouts/Base';
import TopView from "../components/TopView";
import About from "../components/About";
import Theme from "../components/Theme";
import GuestList from "../components/GuestList";
import Guest from "../components/Guest";
import Map from "../components/Map";
import EventList from "../components/EventList";
import EventCard from "../components/EventList/components/EventCard";
import PamphletButton from "../components/PamphletButton";
import Sns from "../components/Sns";
import SideMenu, * as Menu from '../components/SideMenu';
---

<Layout>
	<TopView />
	<Column>
		<SideMenu client:media="(min-width: 880px)" />
		<Base>
			<Menu.Contents>
				<Menu.Anchor id="about" name="蒼翔祭とは？"/>
				<About></About>

				<Menu.Anchor id="theme" name="今年度テーマ"/>
				<Theme></Theme>

				<Menu.Anchor id="guest" name="スペシャルゲスト"/>
				<GuestList>
					<Guest name="hogehoge">
						hogehoge hogehoge
					</Guest>
					<Guest name="hogehoge">
						hogehoge hogehoge
					</Guest>
				</GuestList>

				<Menu.Anchor id="map" name="会場マップ"/>
				<Map></Map>	

				<Menu.Anchor id="events" name="開催イベント"/>
				<EventList>
						<EventCard type="stage">A</EventCard>
						<EventCard type="shop">B</EventCard>
						<EventCard type="company">C</EventCard>
						<EventCard type="exhibit">D</EventCard>
						<EventCard type="kids">E</EventCard>
						<EventCard type="gakusaiEvents">F</EventCard>
				</EventList>

				<Menu.Anchor id="pamphlet" name="パンフレット"/>
				<PamphletButton invalid={false} link="#"></PamphletButton>
				
				<Menu.Anchor id="sns" name="最新情報"/>
				<Sns></Sns>
			</Menu.Contents>
		</Base>
	</Column>
</Layout>